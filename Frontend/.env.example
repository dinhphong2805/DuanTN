# Backend Spring Boot (mặc định http://localhost:8080/api)
# Mỗi người trong nhóm: nếu backend chạy cổng khác hoặc trên máy khác (IP LAN), sửa cho đúng rồi đổi tên file thành .env
#
# Ví dụ cùng máy, cổng mặc định:
# VITE_API_URL=http://localhost:8080/api
#
# Ví dụ máy bạn chạy backend, đồng đội mở frontend trỏ về IP của bạn:
# VITE_API_URL=http://192.168.1.10:8080/api
#
# Sau khi sửa: npm run dev (Vite đọc biến VITE_* lúc khởi động)
